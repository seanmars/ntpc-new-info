{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RescuePolling": {
    "UpstreamUrl": "https://e.ntpc.gov.tw/v3/api/map/dynamic/layer/rescue",
    "IntervalSeconds": 300,
    "RequestTimeoutSeconds": 30
  },
  "MonitorPointStore": {
    "FilePath": "data/monitor-points.json"
  },
  "Nominatim": {
    "BaseUrl": "https://nominatim.openstreetmap.org",
    "UserAgent": "ntpc-new-info-backend/0.1",
    "RequestTimeoutSeconds": 10,
    "MinIntervalMs": 1100
  }
}
