{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RescuePolling": {
    "UpstreamUrl": "https://e.ntpc.gov.tw/v3/api/map/dynamic/layer/rescue",
    "Interval": "00:05:00",
    "RequestTimeout": "00:00:30"
  },
  "MonitorPointStore": {
    "FilePath": "data/monitor-points.json"
  },
  "Nominatim": {
    "BaseUrl": "https://nominatim.openstreetmap.org",
    "UserAgent": "ntpc-new-info-backend/0.1",
    "RequestTimeout": "00:00:10",
    "MinIntervalMs": 1100
  }
}
